# =============================================================
#  NomoLend — Environment Variables
#  Copy this file to .env and fill in the values
# =============================================================

# ── Admin (only needed for initial setup / migration scripts) ──
# After multisig migration, this key is no longer needed
# DEPLOYER_PRIVATE_KEY=0x_YOUR_DEPLOYER_KEY_HERE

# ── Bot wallet (REQUIRED for keeper bots) ──
# Separate wallet with only PRICE_UPDATER_ROLE + LIQUIDATOR_ROLE
BOT_PRIVATE_KEY=0x_YOUR_BOT_PRIVATE_KEY_HERE

# ── RPC Endpoints (failover: primary → secondary → tertiary → public) ──
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_RPC_URL_2=https://base-mainnet.infura.io/v3/YOUR_KEY
# BASE_RPC_URL_3=https://base.llamarpc.com

# ── Multisig (for migration scripts) ──
# SAFE_ADDRESS=0x_YOUR_GNOSIS_SAFE_ADDRESS
# BOT_ADDRESS=0x_YOUR_BOT_WALLET_PUBLIC_ADDRESS

# ── Telegram alerts (recommended) ──
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Discord alerts (optional) ──
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Firebase Admin SDK (optional — path to service account JSON) ──
# FIREBASE_SERVICE_ACCOUNT_KEY=./firebase-key.json

# ── Health API port (default: 4040) ──
# HEALTH_PORT=4040

# ── Dry run mode for keeper bots (no transactions) ──
# DRY_RUN=true
